# Python
__pycache__/
*.py[cod]
.venv/
venv/
.uv/
*.egg-info/
.pytest_cache/
.ruff_cache/

# Dagster
.dagster/
pipeline/.dagster_home/
tmp*/
*.tmp

# Data artifacts (regenerated by the pipeline) — keep the folders, ignore contents
/data/raw/*
/data/clean/*
!/data/raw/.gitkeep
!/data/clean/.gitkeep

# contrib pipelines write their own data/ outputs
contrib/**/data/

# Node / Next.js
node_modules/
web/.next/
web/out/
web/next-env.d.ts
.DS_Store

# Note: web/public/data/*.json IS committed (the dashboard snapshot)
