# Python
__pycache__/
*.py[cod]
.venv/
venv/
.uv/
*.egg-info/
.pytest_cache/
.ruff_cache/

# Dagster
.dagster/
pipeline/.dagster_home/
tmp*/
*.tmp

# Data artifacts (regenerated by the pipeline) — keep the folders, ignore contents
/data/raw/*
/data/clean/*
!/data/raw/.gitkeep
!/data/clean/.gitkeep

# contrib pipelines write their own data/ outputs
contrib/**/data/

# Node / Next.js
node_modules/
web/.next/
web/out/
web/next-env.d.ts
.DS_Store

# Note: web/public/data/*.json IS committed (the dashboard snapshot)

# Slide deck: proprietary / personal-use fonts — NOT redistributable on a public repo.
# (Local copies still render the deck; the public repo falls back to Google-CDN fonts.)
docs/slides/assets/fonts/*.otf
docs/slides/assets/fonts/*.ttf
docs/slides/assets/fonts/*.woff
docs/slides/assets/fonts/*.woff2
docs/slides/assets/fonts/EULA-*.pdf
docs/slides/assets/fonts/*license*.txt
# Slide deck scratch
docs/slides/scratch-ignore.md
